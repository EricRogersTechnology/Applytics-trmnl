{% comment %} Half vertical (400x480 / 520x780). {% endcomment %}
{% if has_data %}
<div class="layout layout--col gap--medium lg:gap--large portrait:gap--large">
  <div class="flex flex--row" style="align-items: center; gap: 14px;">
    {% if app_icon != blank %}<img class="image image-dither" src="{{ app_icon }}" style="width: 58px; height: 58px; border-radius: 13px; flex-shrink: 0;" />{% endif %}
    <span class="title" style="font-size: 25px; line-height: 1.05;">{{ app_name }}</span>
  </div>
  <div class="item"><div class="content">
    <span class="value value--xlarge lg:value--mega">{{ downloads_day }}</span>
    <span class="label">Downloads today</span>
  </div></div>
  <div class="item"><div class="content">
    <span class="value value--large lg:value--xlarge">{{ downloads_7d }}</span>
    <span class="label">Last 7 days</span>
  </div></div>
  <div class="item"><div class="content">
    <span class="value value--large lg:value--xlarge">{{ downloads_30d }}</span>
    <span class="label">Last 30 days</span>
  </div></div>
  <div class="item"><div class="content">
    <span class="value value--small lg:value">{{ currency }} {{ revenue_30d }}</span>
    <span class="label">Proceeds &middot; 30d</span>
  </div></div>
</div>
{% else %}
<div class="layout layout--col layout--center">
  <span class="value value--large">Applytics</span>
  <span class="label">Waiting for data&hellip;</span>
</div>
{% endif %}

<div class="title_bar">
  <span class="title">Applytics</span>
  <span class="instance">{{ updated_at }}</span>
</div>
