# Copy to .env and fill in. .env is gitignored. For GitHub Actions, add these
# as repository Secrets (Settings → Secrets and variables → Actions) instead.

# --- App Store Connect API key (Users and Access → Integrations) ---
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_VENDOR_NUMBER=8XXXXXXX

# The .p8 private key. Locally, point to the file:
ASC_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
# In GitHub Secrets, paste the file CONTENTS into ASC_PRIVATE_KEY instead:
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- TRMNL webhook (from your private plugin's config form) ---
TRMNL_WEBHOOK_URL=https://trmnl.com/api/custom_plugins/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# --- Optional tuning ---
# ASC_STOREFRONT=us        # storefront for star ratings (iTunes lookup)
# DAYS_BACK=35             # how many daily reports to pull
# TOP_APPS=6               # max apps shown in the per-app list
# ASC_REPORT_VERSION=1_1   # pin a sales-report version if needed
# DRY_RUN=1                # print the payload instead of posting to TRMNL
